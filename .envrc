use flake

req_file="bfd9000_web/requirements-dev.txt"
stamp_file=".venv/.bfd9000_requirements_stamp"

# Ensure venv exists and activate
if [ ! -d .venv ]; then
  echo '[direnv] Creating .venv...'
  python -m venv .venv || {
    echo '[direnv] venv creation failed';
    exit 1;
  }
fi
. .venv/bin/activate
export VIRTUAL_ENV="$PWD/.venv"
PATH_add ".venv/bin"

# Only install when requirements change
if [ -f "$req_file" ]; then
  cur_hash="$(python - "$req_file" <<'PY'
import hashlib
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
print(hashlib.sha256(path.read_bytes()).hexdigest())
PY
  )"
  req_needs_install=0
  prev_hash=""
  if [ ! -f "$stamp_file" ]; then
    req_needs_install=1
  else
    IFS= read -r prev_hash < "$stamp_file"
    [ "$cur_hash" != "$prev_hash" ] && req_needs_install=1
  fi
  if [ "$req_needs_install" = "1" ]; then
    echo '[direnv] Installing requirements for venv...'
    python -m pip install -r "$req_file"
    echo "$cur_hash" > "$stamp_file"
    echo "[direnv] Python deps installed."
  else
    echo "[direnv] Python deps already satisfied."
  fi
else
  echo "[direnv] $req_file missing, skipped Python deps install."
fi

unset req_file stamp_file cur_hash prev_hash req_needs_install
